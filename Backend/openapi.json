              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Items Path"
          },
          "failure_policy": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Failure Policy"
          },
          "children": {
            "items": {
              "$ref": "#/components/schemas/FlowNodeResponse"
            },
            "type": "array",
            "title": "Children",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "id",
          "kind",
          "ord",
          "title"
        ],
        "title": "FlowNodeResponse",
        "description": "Public representation of a flow node, including children.\n\nAttributes:\n    id: Node identifier.\n    kind: Node kind (\"api\", \"hermes\", \"foreach\").\n    ord: Sibling order.\n    title: Display title.\n    parent_node_id: Parent identifier, if any.\n    binding_id: Integration binding, if any.\n    input_mapping: Mapping used to build node input.\n    output_mapping: Mapping used to write node output.\n    items_path: For foreach nodes, the path to the list being iterated.\n    failure_policy: How failures are handled.\n    children: Nested child nodes for foreach containers."
      },
