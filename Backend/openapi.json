                  },
                  "type": "array",
                  "title": "Response List Flows Flows Get"
                }
              }
            }
          }
        }
      }
    },
    "/flow_versions/{flow_version_id}": {
      "get": {
        "tags": [
          "Flow Versions"
        ],
        "summary": "Get Flow Version",
        "description": "Retrieve a flow version and its full node tree.\n\nArgs:\n    flow_version_id: The ID of the flow version.\n\nReturns:\n    A FlowVersionResponse containing the version metadata and nested nodes.\n\nRaises:\n    HTTPException: 404 if the flow version does not exist.",
        "operationId": "get_flow_version_flow_versions__flow_version_id__get",
        "parameters": [
          {
            "name": "flow_version_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Flow Version Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlowVersionResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/runs/{run_id}/questions": {
      "get": {
        "tags": [
          "Questions"
        ],
        "summary": "Get Run Questions",
        "description": "List all open questions for a run.\n\nArgs:\n    run_id: The ID of the run.\n\nReturns:\n    A list of open QuestionResponse records.\n\nRaises:\n    HTTPException: 404 if the run does not exist.",
        "operationId": "get_run_questions_runs__run_id__questions_get",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/QuestionResponse"
                  },
                  "title": "Response Get Run Questions Runs  Run Id  Questions Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/runs/{run_id}/tick": {
      "post": {
        "tags": [
          "Runs"
        ],
        "summary": "Tick Run",
        "description": "Advance a run by one execution tick.\n\nA tick evaluates pending node states, executes the next ready node, and\nupdates the run's status. This endpoint returns the run after the tick has\nbeen applied.\n\nArgs:\n    run_id: The ID of the run to advance.\n\nReturns:\n    A RunResponse reflecting the run state after the tick.\n\nRaises:\n    HTTPException: 404 if the run does not exist.",
        "operationId": "tick_run_runs__run_id__tick_post",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/runs/{run_id}": {
      "get": {
        "tags": [
          "Runs"
        ],
        "summary": "Get Run",
        "description": "Retrieve a single run by ID.\n\nArgs:\n    run_id: The ID of the run to retrieve.\n\nReturns:\n    A RunResponse containing the run metadata and node states.\n\nRaises:\n    HTTPException: 404 if the run does not exist.",
        "operationId": "get_run_runs__run_id__get",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/runs/{run_id}/node-states": {
      "get": {
        "tags": [
          "Node States"
        ],
        "summary": "List Node States",
        "description": "List all node states associated with a run.\n\nArgs:\n    run_id: The ID of the parent run.\n\nReturns:\n    A dictionary with a single key, \"node_states\", containing the public\n    representations of each node state.\n\nRaises:\n    HTTPException: 404 if the run does not exist.",
        "operationId": "list_node_states_runs__run_id__node_states_get",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NodeStatesListResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/runs/{run_id}/node-states/{node_state_id}": {
      "get": {
        "tags": [
          "Node States"
        ],
        "summary": "Get Node State",
        "description": "Retrieve a single node state by run ID and node state ID.\n\nArgs:\n    run_id: The ID of the parent run.\n    node_state_id: The ID of the node state to retrieve.\n\nReturns:\n    The public representation of the node state.\n\nRaises:\n    HTTPException: 404 if the run or node state does not exist, or if the\n        node state belongs to a different run.",
        "operationId": "get_node_state_runs__run_id__node_states__node_state_id__get",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          },
          {
            "name": "node_state_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Node State Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NodeStateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/runs/{run_id}/node-states/{node_state_id}/questions": {
      "get": {
        "tags": [
          "Questions"
        ],
        "summary": "Get Node State Questions",
        "description": "List all questions associated with a node state.\n\nArgs:\n    run_id: The ID of the parent run.\n    node_state_id: The ID of the node state whose questions are queried.\n\nReturns:\n    A dictionary with a single key, \"questions\", containing the question\n    records.\n\nRaises:\n    HTTPException: 404 if the run or node state does not exist, or if the\n        node state belongs to a different run.",
        "operationId": "get_node_state_questions_runs__run_id__node_states__node_state_id__questions_get",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          },
          {
            "name": "node_state_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Node State Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NodeStateQuestionsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/runs/{run_id}/node-states/{node_state_id}/answer": {
      "post": {
        "tags": [
          "Questions"
        ],
        "summary": "Answer Node State Question",
        "description": "Answer the first open question for a node state.\n\nThe endpoint answers the oldest open question associated with the node\nstate. It is the caller's responsibility to ensure that questions are\nanswered in the order they were raised.\n\nArgs:\n    run_id: The ID of the parent run.\n    node_state_id: The ID of the node state whose question is answered.\n    body: The answer payload.\n\nReturns:\n    A dictionary with key \"status\" set to \"answered\".\n\nRaises:\n    HTTPException: 404 if the run or node state does not exist, 400 if there\n        is no open question to answer.",
        "operationId": "answer_node_state_question_runs__run_id__node_states__node_state_id__answer_post",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          },
          {
            "name": "node_state_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Node State Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnswerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnswerResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnswerRequest": {
        "properties": {
          "answer": {
            "type": "string",
            "title": "Answer"
          }
        },
        "type": "object",
        "required": [
          "answer"
        ],
        "title": "AnswerRequest",
        "description": "Payload used to answer a question that has paused a node state.\n\nAttributes:\n    answer: The answer text supplied by the caller."
      },
      "AnswerResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "AnswerResponse",
        "description": "Response returned after answering a question."
      },
      "CreateRunRequest": {
        "properties": {
          "flow_slug": {
            "type": "string",
            "title": "Flow Slug",
            "default": "soda-comparison"
