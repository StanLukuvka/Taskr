                "type": "null"
              }
            ],
            "title": "Parent Node Id"
          },
          "binding_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Binding Id"
          },
          "input_mapping": {
            "title": "Input Mapping"
          },
          "output_mapping": {
            "title": "Output Mapping"
          },
          "items_path": {
