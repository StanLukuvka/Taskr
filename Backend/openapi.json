{
  "openapi": "3.1.0",
  "info": {
    "title": "Taskr",
    "version": "0.1.0"
  },
  "paths": {
    "/flow_versions/{flow_version_id}/flow_nodes": {
      "post": {
        "tags": [
          "Flow Nodes"
        ],
        "summary": "Create Flow Node",
        "description": "Create a new flow node within a flow version.\n\nValidates that the target flow version exists and is still in \"draft\"\nstatus, then delegates creation to the repository layer.\n\nArgs:\n    flow_version_id: The ID of the flow version that will own the node.\n    body: The flow node creation payload.\n\nReturns:\n    The newly created flow node record.\n\nRaises:\n    HTTPException: 404 if the flow version does not exist, or 400 if it is\n        not in draft status.",
        "operationId": "create_flow_node_flow_versions__flow_version_id__flow_nodes_post",
        "parameters": [
          {
            "name": "flow_version_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Flow Version Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FlowNodeCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlowNodeResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/runs": {
      "get": {
        "tags": [
          "Runs"
        ],
        "summary": "List Runs",
        "description": "List all runs.\n\nReturns:\n    A list of RunListItem records, ordered by creation time.",
        "operationId": "list_runs_runs_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/RunListItem"
                  },
                  "type": "array",
                  "title": "Response List Runs Runs Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Runs"
        ],
        "summary": "Create Run",
        "description": "Create a new run for a flow.\n\nIf no body is provided, the seeded \"soda-comparison\" demo flow is used\nwith an empty context. This keeps the endpoint usable for quick manual\ntests while also allowing a frontend to specify which flow to run and\nwhat initial context to pass.\n\nArgs:\n    body: Optional run creation payload containing the flow slug and context.\n\nReturns:\n    A RunResponse containing the created run and its initial node states.",
        "operationId": "create_run_runs_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/CreateRunRequest"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Body"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/flows": {
      "get": {
        "tags": [
          "Flows"
        ],
        "summary": "List Flows",
        "description": "List all flows.\n\nReturns:\n    A list of FlowResponse records.",
        "operationId": "list_flows_flows_get",
