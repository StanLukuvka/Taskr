          },
          "binding_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Binding Id"
          },
          "input_mapping": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Input Mapping"
          },
          "output_mapping": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Output Mapping"
          },
          "policy_refs": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Policy Refs"
          }
        },
        "type": "object",
        "required": [
          "kind",
          "ord",
          "title"
        ],
        "title": "FlowNodeCreateRequest",
        "description": "Payload used to create a new node inside a flow version.\n\nAttributes:\n    kind: The node type (e.g., \"question\", \"action\").\n    ord: The display / execution order of the node within the flow.\n    title: Human-readable title for the node.\n    node_id: Optional stable identifier for the node.\n    parent_node_id: Optional identifier of a parent node, for nesting.\n    binding_id: Optional binding reference for external integrations.\n    input_mapping: Optional mapping of input fields for this node.\n    output_mapping: Optional mapping of output fields for this node.\n    policy_refs: Optional policy references attached to the node."
      },
      "FlowNodeResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "kind": {
            "type": "string",
            "title": "Kind"
          },
          "ord": {
            "type": "integer",
            "title": "Ord"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "parent_node_id": {
            "anyOf": [
